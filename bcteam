<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BC Team Building — 28 April</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080c14;
    --yellow: #F5FF5C;
    --coral: #FF6B6B;
    --lime: #5CFF9D;
    --purple: #C47EFF;
    --card: rgba(255,255,255,0.04);
    --border: rgba(255,255,255,0.08);
    --text: #EEEEF0;
    --muted: rgba(255,255,255,0.45);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Plus Jakarta Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── Canvas particles ── */
  #canvas {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 72px 24px 48px;
  }

  .hero-eyebrow {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 18px;
    opacity: 0;
    animation: fadeUp 0.6s 0.1s forwards;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 14vw, 160px);
    line-height: 0.92;
    letter-spacing: 0.01em;
    background: linear-gradient(135deg, var(--yellow) 0%, var(--coral) 50%, var(--purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    opacity: 0;
    animation: fadeUp 0.7s 0.25s forwards;
  }

  .hero-sub {
    font-size: 17px;
    color: var(--muted);
    margin-top: 22px;
    opacity: 0;
    animation: fadeUp 0.6s 0.45s forwards;
  }

  .hero-date-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(245,255,92,0.1);
    border: 1px solid rgba(245,255,92,0.25);
    border-radius: 100px;
    padding: 8px 22px;
    font-size: 14px;
    font-weight: 600;
    color: var(--yellow);
    margin-top: 28px;
    opacity: 0;
    animation: fadeUp 0.6s 0.6s forwards;
  }

  .dot-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--yellow);
    animation: pulse 1.5s ease-in-out infinite;
  }

  /* ── Countdown ── */
  .countdown-wrap {
    position: relative; z-index: 1;
    display: flex;
    justify-content: center;
    gap: 20px;
    padding: 0 24px 56px;
    opacity: 0;
    animation: fadeUp 0.6s 0.8s forwards;
  }

  .cd-block {
    text-align: center;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 16px 22px;
    min-width: 72px;
  }

  .cd-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    line-height: 1;
    color: var(--yellow);
  }

  .cd-label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 4px;
  }

  /* ── Timeline ── */
  .timeline {
    position: relative; z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px 100px;
  }

  .section-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    margin-bottom: 40px;
  }

  .tl-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--border) 10%, var(--border) 90%, transparent);
    transform: translateX(-50%);
  }

  .tl-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.5s, transform 0.5s;
  }

  .tl-item.visible { opacity: 1; transform: translateY(0); }

  .tl-time {
    width: 88px;
    flex-shrink: 0;
    text-align: right;
    padding-top: 18px;
  }

  .tl-time-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.03em;
    color: var(--yellow);
    line-height: 1;
  }

  .tl-time-end {
    font-size: 12px;
    color: var(--muted);
    margin-top: 2px;
  }

  .tl-dot-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 32px;
    padding-top: 20px;
  }

  .tl-dot {
    width: 14px; height: 14px;
    border-radius: 50%;
    border: 2px solid;
    flex-shrink: 0;
    position: relative;
  }

  .tl-dot::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .tl-card {
    flex: 1;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 20px 22px;
    cursor: pointer;
    transition: border-color 0.25s, background 0.25s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .tl-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    border-radius: 18px 0 0 18px;
  }

  .tl-card:hover {
    transform: translateX(4px);
    border-color: rgba(255,255,255,0.16);
  }

  .tl-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .tl-icon {
    font-size: 22px;
    line-height: 1;
  }

  .tl-name {
    font-weight: 600;
    font-size: 16px;
    flex: 1;
    color: var(--text);
  }

  .tl-location {
    font-size: 13px;
    color: var(--muted);
    margin-top: 5px;
  }

  .tl-chevron {
    font-size: 14px;
    color: var(--muted);
    transition: transform 0.3s;
    flex-shrink: 0;
  }

  .tl-card.open .tl-chevron { transform: rotate(180deg); }

  .tl-detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1), opacity 0.3s;
    opacity: 0;
  }

  .tl-card.open .tl-detail {
    max-height: 500px;
    opacity: 1;
  }

  .tl-detail-inner {
    border-top: 1px solid var(--border);
    margin-top: 14px;
    padding-top: 14px;
    font-size: 14px;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
  }

  /* ── Colour variants ── */
  .c-yellow .tl-dot { border-color: var(--yellow); background: rgba(245,255,92,0.15); }
  .c-yellow .tl-card::before { background: var(--yellow); }
  .c-yellow .tl-card:hover { border-color: rgba(245,255,92,0.35); background: rgba(245,255,92,0.04); }

  .c-coral .tl-dot { border-color: var(--coral); background: rgba(255,107,107,0.15); }
  .c-coral .tl-card::before { background: var(--coral); }
  .c-coral .tl-card:hover { border-color: rgba(255,107,107,0.35); background: rgba(255,107,107,0.04); }

  .c-lime .tl-dot { border-color: var(--lime); background: rgba(92,255,157,0.15); }
  .c-lime .tl-card::before { background: var(--lime); }
  .c-lime .tl-card:hover { border-color: rgba(92,255,157,0.35); background: rgba(92,255,157,0.04); }

  .c-purple .tl-dot { border-color: var(--purple); background: rgba(196,126,255,0.15); }
  .c-purple .tl-card::before { background: var(--purple); }
  .c-purple .tl-card:hover { border-color: rgba(196,126,255,0.35); background: rgba(196,126,255,0.04); }

  /* ── Snack game ── */
  .snack-game {
    background: rgba(255,107,107,0.06);
    border: 1px solid rgba(255,107,107,0.2);
    border-radius: 14px;
    padding: 20px;
    margin-top: 14px;
  }

  .snack-title {
    font-weight: 600;
    font-size: 14px;
    color: var(--coral);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .snack-boxes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .snack-box {
    flex: 1;
    min-width: 60px;
    height: 60px;
    background: rgba(255,107,107,0.1);
    border: 1.5px dashed rgba(255,107,107,0.35);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    cursor: pointer;
    transition: transform 0.15s, background 0.2s;
    user-select: none;
    position: relative;
    overflow: hidden;
  }

  .snack-box:hover { transform: scale(1.08); background: rgba(255,107,107,0.18); }

  .snack-box .mystery { font-size: 22px; }
  .snack-box .reveal { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; font-size: 26px; background: rgba(255,107,107,0.25); border-radius: 10px; }
  .snack-box.revealed .mystery { display: none; }
  .snack-box.revealed .reveal { display: flex; }

  .snack-btn {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--coral);
    color: #fff;
    border: none;
    border-radius: 100px;
    padding: 9px 20px;
    font-size: 13px;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
  }

  .snack-btn:hover { opacity: 0.88; transform: scale(0.98); }

  .snack-hint {
    font-size: 12px;
    color: var(--muted);
    margin-top: 10px;
  }

  /* ── Address card ── */
  .addr-card {
    background: rgba(196,126,255,0.06);
    border: 1px solid rgba(196,126,255,0.2);
    border-radius: 14px;
    padding: 16px 18px;
    margin-top: 14px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .addr-icon { font-size: 28px; }

  .addr-info { flex: 1; }

  .addr-name { font-weight: 600; font-size: 14px; color: var(--purple); }
  .addr-text { font-size: 13px; color: var(--muted); margin-top: 2px; }

  .addr-map-btn {
    background: var(--purple);
    color: #fff;
    border: none;
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 12px;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    cursor: pointer;
    transition: opacity 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }

  .addr-map-btn:hover { opacity: 0.85; }

  /* ── Footer ── */
  .footer {
    position: relative; z-index: 1;
    text-align: center;
    padding: 0 24px 60px;
    font-size: 13px;
    color: var(--muted);
  }

  .footer-emoji { font-size: 32px; margin-bottom: 12px; }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.75); }
  }

  @keyframes pop {
    0% { transform: scale(1); }
    40% { transform: scale(1.25); }
    100% { transform: scale(1); }
  }

  .pop { animation: pop 0.3s ease; }

  /* ── Badge ── */
  .badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 100px;
    margin-left: 8px;
    vertical-align: middle;
  }

  .badge-hot { background: rgba(255,107,107,0.18); color: var(--coral); }
  .badge-fun { background: rgba(245,255,92,0.15); color: var(--yellow); }

  /* ── Responsive ── */
  @media (max-width: 560px) {
    .tl-time { width: 70px; }
    .tl-time-text { font-size: 17px; }
    .cd-block { padding: 12px 14px; min-width: 58px; }
    .cd-num { font-size: 34px; }
  }
</style>
</head>
<body>

<canvas id="canvas"></canvas>

<!-- Hero -->
<header class="hero">
  <p class="hero-eyebrow">Monday · 28 April 2025</p>
  <h1 class="hero-title">BC Team<br>Building</h1>
  <p class="hero-sub">One day. Great food. Zero excuses.</p>
  <div class="hero-date-pill">
    <span class="dot-pulse"></span>
    Full programme below
  </div>
</header>

<!-- Countdown -->
<div class="countdown-wrap" id="countdown">
  <div class="cd-block"><div class="cd-num" id="cd-d">00</div><div class="cd-label">Days</div></div>
  <div class="cd-block"><div class="cd-num" id="cd-h">00</div><div class="cd-label">Hours</div></div>
  <div class="cd-block"><div class="cd-num" id="cd-m">00</div><div class="cd-label">Mins</div></div>
  <div class="cd-block"><div class="cd-num" id="cd-s">00</div><div class="cd-label">Secs</div></div>
</div>

<!-- Timeline -->
<main class="timeline">
  <p class="section-label">Programme</p>

  <!-- 1: Main session -->
  <div class="tl-item c-yellow">
    <div class="tl-time">
      <div class="tl-time-text">13:00</div>
      <div class="tl-time-end">→ 16:00</div>
    </div>
    <div class="tl-dot-col"><div class="tl-dot"></div></div>
    <div class="tl-card" onclick="toggle(this)">
      <div class="tl-card-header">
        <span class="tl-icon">🎯</span>
        <span class="tl-name">Main session <span class="badge badge-fun">3 hrs</span></span>
        <span class="tl-chevron">▾</span>
      </div>
      <div class="tl-location">📍 1st floor · Hall room 1</div>
      <div class="tl-detail">
        <div class="tl-detail-inner">
          Kick off the day together in Hall Room 1. Three hours of collaboration, energy, and ideas. Come ready to contribute — the best sessions happen when everyone's in the room mentally, not just physically.
          <br><br>
          <strong style="color: var(--yellow);">Tips:</strong> Grab a coffee before heading in. Notebooks welcome, phones on silent. 🙏
        </div>
      </div>
    </div>
  </div>

  <!-- 2: Mingle & drinks -->
  <div class="tl-item c-coral">
    <div class="tl-time">
      <div class="tl-time-text">16:00</div>
      <div class="tl-time-end">→ 17:30</div>
    </div>
    <div class="tl-dot-col"><div class="tl-dot"></div></div>
    <div class="tl-card" onclick="toggle(this)">
      <div class="tl-card-header">
        <span class="tl-icon">🎉</span>
        <span class="tl-name">Mingle & drinks <span class="badge badge-hot">+ game!</span></span>
        <span class="tl-chevron">▾</span>
      </div>
      <div class="tl-location">📍 14th floor</div>
      <div class="tl-detail">
        <div class="tl-detail-inner">
          Head upstairs to the 14th floor for drinks, good vibes, and stunning views. But that's not all…

          <div class="snack-game">
            <div class="snack-title">🙈 Blind Snack Testing Challenge</div>
            <p style="font-size:13px; color:rgba(255,255,255,0.55); margin-bottom:14px; line-height:1.6;">
              Blindfolded. Mystery snacks. Zero shame. Tap the boxes to reveal what's hiding — and find out if your taste buds can be trusted.
            </p>
            <div class="snack-boxes" id="snack-boxes">
              <div class="snack-box" onclick="revealSnack(this, '🧀')"><span class="mystery">❓</span><span class="reveal">🧀</span></div>
              <div class="snack-box" onclick="revealSnack(this, '🍫')"><span class="mystery">❓</span><span class="reveal">🍫</span></div>
              <div class="snack-box" onclick="revealSnack(this, '🥨')"><span class="mystery">❓</span><span class="reveal">🥨</span></div>
              <div class="snack-box" onclick="revealSnack(this, '🍬')"><span class="mystery">❓</span><span class="reveal">🍬</span></div>
              <div class="snack-box" onclick="revealSnack(this, '🌶️')"><span class="mystery">❓</span><span class="reveal">🌶️</span></div>
            </div>
            <p class="snack-hint">👆 Tap to reveal each mystery snack</p>
            <button class="snack-btn" onclick="resetSnacks()">🔄 Reset & play again</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 3: Depart -->
  <div class="tl-item c-lime">
    <div class="tl-time">
      <div class="tl-time-text">17:30</div>
    </div>
    <div class="tl-dot-col"><div class="tl-dot"></div></div>
    <div class="tl-card" onclick="toggle(this)">
      <div class="tl-card-header">
        <span class="tl-icon">🚕</span>
        <span class="tl-name">Depart to dinner</span>
        <span class="tl-chevron">▾</span>
      </div>
      <div class="tl-location">Heading to Tatakii Asian, Majorstuen</div>
      <div class="tl-detail">
        <div class="tl-detail-inner">
          We leave together at 17:30 sharp — don't be the one who holds up the convoy! The restaurant is in the Majorstuen neighbourhood, approx 10–15 min away.
          <br><br>
          <strong style="color: var(--lime);">Pro tip:</strong> Hit the bathroom before you leave. 🚻
        </div>
      </div>
    </div>
  </div>

  <!-- 4: Arrive Tatakii -->
  <div class="tl-item c-purple">
    <div class="tl-time">
      <div class="tl-time-text">18:00</div>
      <div class="tl-time-end">→ 20:00</div>
    </div>
    <div class="tl-dot-col"><div class="tl-dot"></div></div>
    <div class="tl-card" onclick="toggle(this)">
      <div class="tl-card-header">
        <span class="tl-icon">🍣</span>
        <span class="tl-name">Dinner at Tatakii Asian</span>
        <span class="tl-chevron">▾</span>
      </div>
      <div class="tl-location">📍 Middelthuns gate 25, 0368 Oslo</div>
      <div class="tl-detail">
        <div class="tl-detail-inner">
          A modern Asian restaurant fusing Japanese and Chinese cuisine, right by Frogner Park. Think sushi, sashimi, crispy duck, and inspired wok dishes — paired with great company.

          <div class="addr-card">
            <span class="addr-icon">🗺️</span>
            <div class="addr-info">
              <div class="addr-name">Tatakii Asian</div>
              <div class="addr-text">Middelthuns gate 25, 0368 Oslo<br>📞 +47 23 62 40 20</div>
            </div>
            <a class="addr-map-btn" href="https://maps.google.com/?q=Middelthuns+gate+25,+0368+Oslo" target="_blank">Open map ↗</a>
          </div>
        </div>
      </div>
    </div>
  </div>

</main>

<!-- Footer -->
<footer class="footer">
  <div class="footer-emoji">🥂</div>
  <p>See you there, BC team!</p>
  <p style="margin-top:6px; font-size:12px;">Questions? Slack the organiser.</p>
</footer>

<script>
// ── Floating particles ──
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
let W, H, particles = [];

const COLORS = ['#F5FF5C','#FF6B6B','#5CFF9D','#C47EFF','rgba(255,255,255,0.25)'];

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}

function randBetween(a, b) { return a + Math.random() * (b - a); }

function initParticles() {
  particles = [];
  for (let i = 0; i < 55; i++) {
    particles.push({
      x: randBetween(0, W),
      y: randBetween(0, H),
      r: randBetween(1, 3.5),
      dx: randBetween(-0.25, 0.25),
      dy: randBetween(-0.35, -0.1),
      alpha: randBetween(0.08, 0.4),
      color: COLORS[Math.floor(Math.random() * COLORS.length)]
    });
  }
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  particles.forEach(p => {
    ctx.save();
    ctx.globalAlpha = p.alpha;
    ctx.fillStyle = p.color;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
    p.x += p.dx; p.y += p.dy;
    if (p.y < -10) { p.y = H + 10; p.x = randBetween(0, W); }
    if (p.x < -10) p.x = W + 10;
    if (p.x > W + 10) p.x = -10;
  });
  requestAnimationFrame(draw);
}

window.addEventListener('resize', () => { resize(); initParticles(); });
resize(); initParticles(); draw();

// ── Intersection observer for timeline ──
const obs = new IntersectionObserver(entries => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('visible'), i * 80);
      obs.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.tl-item').forEach(el => obs.observe(el));

// ── Card toggle ──
function toggle(card) {
  const isOpen = card.classList.contains('open');
  document.querySelectorAll('.tl-card.open').forEach(c => c.classList.remove('open'));
  if (!isOpen) card.classList.add('open');
}

// ── Snack game ──
function revealSnack(box, snack) {
  if (box.classList.contains('revealed')) return;
  box.classList.add('revealed', 'pop');
  setTimeout(() => box.classList.remove('pop'), 300);
  spawnConfetti(box);
}

function resetSnacks() {
  document.querySelectorAll('.snack-box').forEach(b => b.classList.remove('revealed', 'pop'));
}

// Mini confetti burst on snack reveal
function spawnConfetti(el) {
  const rect = el.getBoundingClientRect();
  const cx = rect.left + rect.width / 2;
  const cy = rect.top + rect.height / 2;
  for (let i = 0; i < 14; i++) {
    const div = document.createElement('div');
    const color = COLORS[Math.floor(Math.random() * COLORS.length)];
    const angle = Math.random() * Math.PI * 2;
    const dist = 40 + Math.random() * 60;
    div.style.cssText = `
      position: fixed;
      left: ${cx}px; top: ${cy}px;
      width: ${4 + Math.random() * 5}px; height: ${4 + Math.random() * 5}px;
      border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
      background: ${color};
      pointer-events: none;
      z-index: 999;
      transition: transform 0.6s cubic-bezier(0.1,0.8,0.2,1), opacity 0.6s;
      transform: translate(-50%, -50%);
    `;
    document.body.appendChild(div);
    requestAnimationFrame(() => {
      div.style.transform = `translate(calc(-50% + ${Math.cos(angle)*dist}px), calc(-50% + ${Math.sin(angle)*dist}px)) rotate(${Math.random()*360}deg)`;
      div.style.opacity = '0';
    });
    setTimeout(() => div.remove(), 700);
  }
}

// ── Countdown to 28 April 2025 13:00 Oslo time (UTC+2) ──
const target = new Date('2025-04-28T13:00:00+02:00').getTime();

function updateCD() {
  const now = Date.now();
  let diff = target - now;
  if (diff < 0) diff = 0;
  const d = Math.floor(diff / 86400000);
  const h = Math.floor((diff % 86400000) / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  const s = Math.floor((diff % 60000) / 1000);
  document.getElementById('cd-d').textContent = String(d).padStart(2,'0');
  document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
  document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
  document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
}

updateCD();
setInterval(updateCD, 1000);
</script>
